From: kayalew123 <kayalew123@users.noreply.github.com>
Date: Tue, 7 Jul 2026 03:30:28 +0000
Subject: [PATCH 6/7] test: add regression tests for listening-now recency and
 rating notifications

Issues #2 and #4 had no test coverage when they shipped. Adds four
tests: stale (5h) events excluded from listening-now, current (5min)
events included, rating a friend's song creates a song_rated
notification for the sharer, and self-ratings do not self-notify.
---
 tests/test_feed_and_notifications.py | 101 +++++++++++++++++++++++++++
 1 file changed, 101 insertions(+)
 create mode 100644 tests/test_feed_and_notifications.py

diff --git a/tests/test_feed_and_notifications.py b/tests/test_feed_and_notifications.py
new file mode 100644
index 0000000..629de83
--- /dev/null
+++ b/tests/test_feed_and_notifications.py
@@ -0,0 +1,101 @@
+"""
+tests/test_feed_and_notifications.py — Mixtape
+
+Regression tests for Issue #2 (stale entries in Friends Listening Now)
+and Issue #4 (missing notification when a shared song is rated).
+Neither service had test coverage when these bugs shipped; these tests
+would have caught both.
+"""
+
+import pytest
+from datetime import datetime, timedelta, timezone
+from app import create_app, db
+from models import User, Song, ListeningEvent, friendships
+from services.feed_service import get_friends_listening_now
+from services.notification_service import rate_song, get_notifications
+
+
+@pytest.fixture
+def app():
+    app = create_app({"TESTING": True, "SQLALCHEMY_DATABASE_URI": "sqlite:///:memory:"})
+    with app.app_context():
+        db.create_all()
+        yield app
+        db.drop_all()
+
+
+@pytest.fixture
+def seed_friends(app):
+    """Two friends, one shared song, and listening events at controlled ages."""
+    with app.app_context():
+        viewer = User(username="viewer", email="viewer@example.com")
+        friend = User(username="friend", email="friend@example.com")
+        db.session.add_all([viewer, friend])
+        db.session.flush()
+
+        db.session.execute(friendships.insert().values(user_id=viewer.id, friend_id=friend.id))
+        db.session.execute(friendships.insert().values(user_id=friend.id, friend_id=viewer.id))
+
+        shared_song = Song(title="Viewer's Anthem", artist="Test Artist", shared_by=viewer.id)
+        db.session.add(shared_song)
+        db.session.commit()
+        yield {"viewer": viewer, "friend": friend, "song": shared_song}
+
+
+def test_listening_now_excludes_stale_events(app, seed_friends):
+    """
+    Regression test for Issue #2: a friend whose only listening event is
+    hours old must NOT appear in the 'Listening Now' feed. The bug was a
+    24-hour RECENT_THRESHOLD, which surfaced yesterday's listens as 'now'.
+    """
+    with app.app_context():
+        stale_event = ListeningEvent(
+            user_id=seed_friends["friend"].id,
+            song_id=seed_friends["song"].id,
+            listened_at=datetime.now(timezone.utc) - timedelta(hours=5),
+        )
+        db.session.add(stale_event)
+        db.session.commit()
+
+        feed = get_friends_listening_now(seed_friends["viewer"].id)
+        assert feed == []  # Pre-fix, the 5-hour-old event appeared here
+
+
+def test_listening_now_includes_current_events(app, seed_friends):
+    """A friend listening within the last 30 minutes appears in the feed."""
+    with app.app_context():
+        current_event = ListeningEvent(
+            user_id=seed_friends["friend"].id,
+            song_id=seed_friends["song"].id,
+            listened_at=datetime.now(timezone.utc) - timedelta(minutes=5),
+        )
+        db.session.add(current_event)
+        db.session.commit()
+
+        feed = get_friends_listening_now(seed_friends["viewer"].id)
+        assert len(feed) == 1
+        assert feed[0]["friend"]["username"] == "friend"
+
+
+def test_rating_notifies_song_sharer(app, seed_friends):
+    """
+    Regression test for Issue #4: rating a friend's shared song must create
+    a 'song_rated' notification for the sharer. The bug was that rate_song
+    never called create_notification at all.
+    """
+    with app.app_context():
+        rate_song(seed_friends["friend"].id, seed_friends["song"].id, 5)
+
+        notifs = get_notifications(seed_friends["viewer"].id)
+        assert len(notifs) == 1
+        assert notifs[0]["type"] == "song_rated"
+        assert "friend" in notifs[0]["body"]
+
+
+def test_rating_own_song_does_not_notify(app, seed_friends):
+    """Rating your own shared song should not generate a self-notification."""
+    with app.app_context():
+        rate_song(seed_friends["viewer"].id, seed_friends["song"].id, 4)
+
+        notifs = get_notifications(seed_friends["viewer"].id)
+        assert notifs == []

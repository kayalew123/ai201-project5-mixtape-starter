From 8b209073c634ddcd3f2743157fdb913fc4d3bb3c Mon Sep 17 00:00:00 2001
From: kayalew123 <kayalew123@users.noreply.github.com>
Date: Tue, 7 Jul 2026 03:29:28 +0000
Subject: [PATCH 3/7] fix: remove tag outerjoin from song search that
 duplicated rows
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

search_songs outer-joined Song to the song_tags association table even
though the join contributed nothing to the filter (which only checks
title/artist). The join multiplies each matching song by its tag count
at the SQL level — a 3-tag song comes back as 3 rows. The duplication
was masked here only because the legacy Query API silently
deduplicates full-entity results; the same statement run through the
2.0-style select() API returns the duplicates. Tags are already loaded
via the Song.tags relationship (lazy='subquery'), so the join is
removed entirely.
---
 services/search_service.py | 3 +--
 1 file changed, 1 insertion(+), 2 deletions(-)

diff --git a/services/search_service.py b/services/search_service.py
index 7722dc1..20071ac 100644
--- a/services/search_service.py
+++ b/services/search_service.py
@@ -5,7 +5,7 @@ Handles song search logic.
 """
 
 from app import db
-from models import Song, Tag, song_tags
+from models import Song
 
 
 def search_songs(query: str) -> list[dict]:
@@ -24,7 +24,6 @@ def search_songs(query: str) -> list[dict]:
     """
     results = (
         db.session.query(Song)
-        .outerjoin(song_tags, Song.id == song_tags.c.song_id)
         .filter(
             db.or_(
                 Song.title.ilike(f"%{query}%"),
-- 

From 2548f5993a4cc5209da85aed68d89a63db3d84db Mon Sep 17 00:00:00 2001
From: kayalew123 <kayalew123@users.noreply.github.com>
Date: Tue, 7 Jul 2026 03:29:28 +0000
Subject: [PATCH 2/7] fix: tighten listening-now window from 24 hours to 30
 minutes
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

get_friends_listening_now used RECENT_THRESHOLD = timedelta(hours=24),
so any friend who listened within the past day — including late last
night — appeared in the 'Listening Now' feed. A 24-hour window
describes daily activity, not 'now'. Reduced the threshold to 30
minutes so the feed only shows genuinely current listening. The
activity feed (get_activity_feed) is intentionally unfiltered by
recency and is unaffected.
---
 services/feed_service.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/services/feed_service.py b/services/feed_service.py
index 52a5095..bf1d36e 100644
--- a/services/feed_service.py
+++ b/services/feed_service.py
@@ -10,7 +10,7 @@ from app import db
 from models import User, Song, ListeningEvent
 
 
-RECENT_THRESHOLD = timedelta(hours=24)
+RECENT_THRESHOLD = timedelta(minutes=30)
 
 
 def get_friends_listening_now(user_id: str) -> list[dict]:
-- 

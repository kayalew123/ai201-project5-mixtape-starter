From f7e33f88ac804d2b1909ba6226ea2a1170804b0c Mon Sep 17 00:00:00 2001
From: kayalew123 <kayalew123@users.noreply.github.com>
Date: Tue, 7 Jul 2026 03:29:28 +0000
Subject: [PATCH 5/7] fix: return all playlist songs instead of dropping the
 last one

get_playlist_songs sliced the ordered result with songs[:-1], which
unconditionally drops the final element. Since songs are ordered
ascending by position, the highest-position (most recently added) song
never appeared. Returning the full list fixes it; an empty playlist
still returns [] since [][:-1] and [] behave the same.
---
 services/playlist_service.py | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/services/playlist_service.py b/services/playlist_service.py
index bac97cc..5a4bab6 100644
--- a/services/playlist_service.py
+++ b/services/playlist_service.py
@@ -63,7 +63,7 @@ def get_playlist_songs(playlist_id: str) -> list[dict]:
         .all()
     )
 
-    return [song.to_dict() for song in songs[:-1]]
+    return [song.to_dict() for song in songs]
 
 
 def get_playlist(playlist_id: str) -> dict:
